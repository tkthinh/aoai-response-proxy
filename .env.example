PORT=3000
LOG_LEVEL=INFO
LOG_BODY_LIMIT=4000

# Azure OpenAI base URL. Keep this as the resource host unless you intentionally use /openai/v1 in the value.
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com

# Optional: only set if your chosen Azure URL strategy requires it.
AZURE_OPENAI_API_VERSION=

# Managed Identity scope. Confirm the correct value for your Azure OpenAI setup.
AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# Optional: only required for user-assigned managed identity.
AZURE_CLIENT_ID=

# Required inbound shared secret used by Codex CLI when calling this proxy.
PROXY_API_KEY=change-me

# Optional model alias mapping: incoming=azure-deployment-name
MODEL_ALIASES=gpt-5.2=codex-gpt5-2,gpt-4.1=my-gpt41-deployment